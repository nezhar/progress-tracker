# Copy to .env and adjust. Never commit .env.

# Title shown on the participant and admin pages.
WORKSHOP_TITLE=Workshop Progress

# Password for /admin (user: admin). Required.
ADMIN_PASSWORD=change-me

# Shared code participants must enter to join. Empty = anyone can join.
# Show it on a slide; it only gates joining, not an account.
PARTICIPANT_PASSCODE=

# Host port the app is published on (container always listens on 8000).
PORT=8000

# Checklist columns shown to participants, comma-separated.
EXERCISES=Setup,Ex 1,Ex 2,Ex 3,Ex 4,Ex 5,Ex 6

# Abuse guards: join cap and questions per participant.
MAX_PARTICIPANTS=200
MAX_QUESTIONS_PER_PERSON=20
